@page "/index.html"
@inherits IndexPage
<link href="SoundPitchExtension.styles.css" rel="stylesheet" />

<div class="terminal">
    <div class="terminal-header">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <a class="title" href="https://shaafyousaf.me" target="_blank">made by Shaaf Yousaf</a>
    </div>
    <div class="terminal-body">
        <div class="hero-section">
            <div class="version-tag">V1.9.3 - MIT Lisence</div>
            <h1 class="hero-title">Slowed<br>Enhanced</h1>
            <p class="hero-subtitle">Your audio toolkit is ready</p>

            <div class="contribute-msg">
                Know <strong>C# or JavaScript?</strong> This extension is now Open Source —
                fix a bug, add a feature, or just poke around. Next update will include your addition.
            </div>

            <div class="actions">
                <a class="btn-primary" href="https://github.com/shaafyousaf/Slowed-Enhanced" target="_blank"> ⌥ View Source on GitHub</a>
                <a class="btn-secondary" href="https://github.com/shaafyousaf/Slowed-Enhanced/issues" target="_blank">Report a Bug</a>
            </div>


        </div>

        @* <div style="flex: 1; display: flex; flex-direction: column; overflow-y: scroll;     scrollbar-width: none;">


            <div class="content-section" style="flex: 1;">
                <div class="section-header">
                    <h2 class="section-title">Core Features</h2>
                </div>
                <div class="specs-list">
                    <div class="spec-item">
                        <div class="spec-name">Reset</div>
                        <div class="spec-value">Instant</div>
                    </div>
                    <div class="spec-item">
                        <div class="spec-name">Volume</div>
                        <div class="spec-value">0–2x</div>
                    </div>
                    <div class="spec-item">
                        <div class="spec-name">Speed</div>
                        <div class="spec-value">0.5–2x</div>
                    </div>
                    <div class="spec-item">
                        <div class="spec-name">Reverb</div>
                        <div class="spec-value">3 modes</div>
                    </div>
                </div>
            </div>
        </div> *@
    </div>
</div>


<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(45deg, black, #434c7e54, #001b34);
        min-height: 100vh;
        display: flex;
        align-items: center;
        background-size: 400% 400%;
        justify-content: center;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        padding: 20px;
        animation: backBodyAnim 15s infinite;
    }



    @@keyframes backBodyAnim {
        0%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 0%;
    }

    100% {
        background-position: 0% 50%;
    }

    }
</style>